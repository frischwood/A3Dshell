# Logs
*.log
*.log.*

# Temporary files
tmp/
temp/
*.tmp
*.temp

# User configurations (optionally commit)
# config/*.ini  # Uncomment to ignore user configs

# Keep example configs
!config/example*.ini

# Documentation (can be generated)
# Uncomment if you don't want these in git:
# IMPLEMENTATION_STATUS.md
# COMPLETION_SUMMARY.md
# SETUP_COMPLETE.md

# Downloaded TLM data
input/tlm/*

# Jupyter notebooks (if any)
*.ipynb
.ipynb_checkpoints/

# OS specific
Thumbs.db
.DS_Store

# Backup files
*.bak
*.backup
*~

